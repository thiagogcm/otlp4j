<?xml version="1.0" encoding="UTF-8"?>
<!-- Root at INFO keeps gRPC/Netty chatter down; otlp4j at DEBUG surfaces the SDK's own logs. -->
<configuration>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <logger name="dev.nthings.otlp4j" level="DEBUG"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
